# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — Del Parque Sistema
# Copiá este archivo como `.env` y completá los valores reales.
# NUNCA subas el .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Frontend (seguras para el cliente; protegidas por RLS en la base)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Supabase — Solo servidor (NUNCA exponer en el frontend)
# Usada por las funciones serverless en /api y por los scripts de seed.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
